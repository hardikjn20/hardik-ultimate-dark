  "tokenColors": [
    {
      "name": "Base foreground",
      "scope": ["source", "text"],
      "settings": { "foreground": "#E8D5FF" }
    },
    {
      "name": "Comments",
      "scope": ["comment", "comment.line", "comment.block", "comment.block.documentation", "punctuation.definition.comment"],
      "settings": { "foreground": "#636366", "fontStyle": "italic" }
    },
    {
      "name": "JSDoc tags",
      "scope": ["storage.type.class.jsdoc", "punctuation.definition.block.tag.jsdoc", "entity.name.type.instance.jsdoc"],
      "settings": { "foreground": "#636366", "fontStyle": "italic" }
    },
    {
      "name": "Keywords — if else for while do switch break continue return yield throw try catch finally",
      "scope": ["keyword.control", "keyword.control.conditional", "keyword.control.loop", "keyword.control.switch", "keyword.control.flow", "keyword.control.exception", "keyword.control.trycatch"],
      "settings": { "foreground": "#FF2D78" }
    },
    {
      "name": "Keywords — import export from as require",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as", "keyword.other.import", "keyword.other.package"],
      "settings": { "foreground": "#FF2D78" }
    },
    {
      "name": "Keywords — new delete typeof instanceof void in of async await",
      "scope": ["keyword.operator.new", "keyword.operator.delete", "keyword.operator.typeof", "keyword.operator.instanceof", "keyword.operator.void", "keyword.operator.expression", "keyword.operator.in", "keyword.operator.of", "keyword.other"],
      "settings": { "foreground": "#FF2D78" }
    },
    {
      "name": "Storage — let const var function class type interface enum abstract",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#FF2D78" }
    },
    {
      "name": "Storage — arrow =>",
      "scope": ["storage.type.function.arrow"],
      "settings": { "foreground": "#FF2D78" }
    },
    {
      "name": "Operators — arithmetic assignment bitwise",
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.bitwise", "keyword.operator.augmented-assignment"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Operators — logical && || ?? !",
      "scope": ["keyword.operator.logical"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Operators — comparison === !== < > <= >=",
      "scope": ["keyword.operator.comparison", "keyword.operator.relational"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Operators — spread rest ternary optional",
      "scope": ["keyword.operator.spread", "keyword.operator.rest", "keyword.operator.optional", "keyword.operator.nullish", "keyword.operator.ternary"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Functions — user-defined",
      "scope": ["entity.name.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#007AFF" }
    },
    {
      "name": "Functions — library support builtins",
      "scope": ["support.function", "support.function.builtin", "support.function.console"],
      "settings": { "foreground": "#007AFF" }
    },
    {
      "name": "Functions — Python dunder builtins",
      "scope": ["support.function.magic.python", "support.function.builtin.python"],
      "settings": { "foreground": "#007AFF" }
    },
    {
      "name": "Functions — SQL aggregate",
      "scope": ["support.function.aggregate.sql", "support.function.sql", "support.function.string.sql", "support.function.datetime.sql"],
      "settings": { "foreground": "#007AFF" }
    },
    {
      "name": "Functions — C++ scope resolution",
      "scope": ["entity.name.scope-resolution.cpp", "entity.name.scope-resolution.function.call.cpp"],
      "settings": { "foreground": "#007AFF" }
    },
    {
      "name": "Variables — normal",
      "scope": ["variable", "variable.other", "variable.other.readwrite", "variable.other.readwrite.alias"],
      "settings": { "foreground": "#E8D5FF" }
    },
    {
      "name": "Variables — object",
      "scope": ["variable.other.object"],
      "settings": { "foreground": "#E8D5FF" }
    },
    {
      "name": "Variables — members properties",
      "scope": ["variable.other.member", "variable.other.property", "variable.other.object.property"],
      "settings": { "foreground": "#8E8E93" }
    },
    {
      "name": "Variables — this self super (italic)",
      "scope": ["variable.language.this", "variable.language.self", "variable.language.super", "variable.language.arguments", "variable.language"],
      "settings": { "foreground": "#E8D5FF", "fontStyle": "italic" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.function.parameters variable.other"],
      "settings": { "foreground": "#AFFF00" }
    },
    {
      "name": "Constants — CAPS_CASE",
      "scope": ["variable.other.constant", "variable.other.constant.object"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Constants — language true false null None undefined",
      "scope": ["constant.language"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Constants — numeric",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Constants — enum members",
      "scope": ["variable.other.enummember"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Constants — escape chars \\n \\t",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#00E5CC" }
    },
    {
      "name": "Constants — other",
      "scope": ["constant.other"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "Classes — definitions",
      "scope": ["entity.name.type.class", "entity.name.class"],
      "settings": { "foreground": "#BF5AF2" }
    },
    {
      "name": "Types — interface enum alias",
      "scope": ["entity.name.type", "entity.name.type.interface", "entity.name.type.enum", "entity.name.type.alias"],
      "settings": { "foreground": "#BF5AF2" }
    },
    {
      "name": "Namespaces modules",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#BF5AF2" }
    },
    {
      "name": "Type annotations — string number boolean any",
      "scope": ["support.type", "support.type.builtin"],
      "settings": { "foreground": "#BF5AF2" }
    },
    {
      "name": "Generic type parameters T K V (italic)",
      "scope": ["entity.name.type.parameter"],
      "settings": { "foreground": "#BF5AF2", "fontStyle": "italic" }
    },
    {
      "name": "Inherited class — extends implements",
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#BF5AF2", "fontStyle": "italic" }
    },
    {
      "name": "Decorators — @Component @Injectable @property @staticmethod @Override",
      "scope": ["meta.decorator", "entity.name.function.decorator", "entity.name.function.decorator.python", "punctuation.definition.decorator", "storage.type.annotation.java", "meta.declaration.annotation.java", "punctuation.definition.annotation.java"],
      "settings": { "foreground": "#00E5CC" }
    },
    {
      "name": "Strings — all plain",
      "scope": ["string", "string.quoted.single", "string.quoted.double", "string.quoted.backtick"],
      "settings": { "foreground": "#2ECC71" }
    },
    {
      "name": "Strings — template f-strings",
      "scope": ["string.template", "string.interpolated"],
      "settings": { "foreground": "#2ECC71" }
    },
    {
      "name": "Strings — regex",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#2ECC71", "fontStyle": "italic" }
    },
    {
      "name": "Template expression ${}",
      "scope": ["meta.template.expression", "punctuation.definition.template-expression.begin", "punctuation.definition.template-expression.end"],
      "settings": { "foreground": "#FFD60A" }
    },
    {
      "name": "HTML — tag names",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#FF2D78" }
    },
    {
      "name": "HTML — attribute names",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#00E5CC" }
    },
    {
      "name": "HTML — attribute string values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#2ECC71" }
    },
    {
      "name": "HTML — DOCTYPE",
      "scope": ["meta.tag.sgml", "meta.tag.sgml.doctype"],
      "settings": { "foreground": "#636366" }
    },
    {
      "name": "JSX TSX — React component tags",
      "scope": ["entity.name.tag.jsx", "entity.name.tag.tsx", "support.class.component.jsx", "support.class.component.tsx"],
      "settings": { "foreground": "#BF5AF2" }
    },
    {
      "name": "JSX TSX — expression delimiters { }",
