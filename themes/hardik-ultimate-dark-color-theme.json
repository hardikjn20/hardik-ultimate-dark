  "tokenColors": [
    {
      "name": "Base",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#D0E8FF"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#375060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSDoc tags",
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#375060",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords \u2014 control",
      "scope": [
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.switch",
        "keyword.control.flow",
        "keyword.control.exception",
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#FF6B9D"
      }
    },
    {
      "name": "Keywords \u2014 modules",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.other.import",
        "keyword.other.package"
      ],
      "settings": {
        "foreground": "#FF6B9D"
      }
    },
    {
      "name": "Keywords \u2014 other",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.void",
        "keyword.operator.expression",
        "keyword.operator.in",
        "keyword.operator.of",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#FF6B9D"
      }
    },
    {
      "name": "Storage \u2014 declarations",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF6B9D"
      }
    },
    {
      "name": "Storage \u2014 arrow",
      "scope": [
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#FF6B9D"
      }
    },
    {
      "name": "Operators \u2014 arithmetic assignment",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.augmented-assignment"
      ],
      "settings": {
        "foreground": "#FFC300"
      }
    },
    {
      "name": "Operators \u2014 logical",
      "scope": [
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#FFC300"
      }
    },
    {
      "name": "Operators \u2014 comparison",
      "scope": [
        "keyword.operator.comparison",
        "keyword.operator.relational"
      ],
      "settings": {
        "foreground": "#FFC300"
      }
    },
    {
      "name": "Operators \u2014 spread ternary optional",
      "scope": [
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.optional",
        "keyword.operator.nullish",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#FFC300"
      }
    },
    {
      "name": "Functions \u2014 user defined",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#40C4FF"
      }
    },
    {
      "name": "Functions \u2014 library support",
      "scope": [
        "support.function",
        "support.function.builtin",
        "support.function.console"
